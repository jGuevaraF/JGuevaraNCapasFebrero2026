@model ML.Usuario

@{
    ViewBag.Title = "GetAll";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("GetAll", "Usuario", FormMethod.Post))
{
    @Html.LabelFor(model => model.BusquedaAbierta.Nombre)
    @Html.TextBoxFor(model => model.BusquedaAbierta.Nombre)

    @Html.LabelFor(model => model.BusquedaAbierta.ApellidoPaterno)
    @Html.TextBoxFor(model => model.BusquedaAbierta.ApellidoPaterno)

    @Html.LabelFor(model => model.BusquedaAbierta.ApellidoMaterno)
    @Html.TextBoxFor(model => model.BusquedaAbierta.ApellidoMaterno)

    @Html.DropDownListFor(model => model.BusquedaAbierta.IdRol, new SelectList(Model.Rol.Roles, "IdRol", "Nombre"), "Selecciona un Rol")

    <button type="submit">Buscar usuario</button>
}

@Html.ActionLink("Agregar", "Form", "Usuario", new { @class = "btn btn-success", @id = "Boton" })



@if (Model.Usuarios.Count > 0)
{
    //impirmir una tabla

    <div class="container">
        <div class="row">
            <div class="col-12">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr class="text-center">

                            <th>Estatus</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Rol</th>
                            <th>Direccion</th>
                            <th>Imagen</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (ML.Usuario usuario in Model.Usuarios)
                        {


                            <tr class="text-center">
                                <td>
                                    @if (usuario.Estatus)
                                    {
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckChecked" checked onchange="ChangeEstatus(this, @usuario.IdUsuario)">
                                        </div>

                                    }
                                    else
                                    {
                                        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckChecked">
                                    }
                                </td>
                                <td>@usuario.Nombre @usuario.ApellidoPaterno @usuario.ApellidoMaterno</td>
                                <td>@usuario.ApellidoPaterno</td>
                                <td>@usuario.Rol.Nombre</td>

                                <td>
                                    @usuario.Direccion.Calle , #@usuario.Direccion.NumeroExterior , @usuario.Direccion.NumeroInterior
                                </td>

                                <td>
                                    @if (usuario.Imagen.Count() > 0)
                                    {
                                        <img src="data:image/*;base64,@Convert.ToBase64String(usuario.Imagen)" />
                                    }
                                    else
                                    {
                                        @*<img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" />*@
                                        <img id="imgUsuario" src="~/Content/Image/UserImage.png" width="200" height="200" />
                                    }
                                </td>

                                <td>
                                    <a href="@Url.Action("Form", "Usuario", new {idUsuario = usuario.IdUsuario})" class="btn btn-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a href="@Url.Action("Delete", "Usuario", new {IdUsuario = usuario.IdUsuario})" onclick="return confirm('Estas seguro de eliminarlo?')" class="btn btn-danger">
                                        <i class="bi bi-person-x-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

}
else
{

    <div class="alert alert-danger" role="alert">
        <p>Hay un error @ViewBag.ErrorMessage </p>

    </div>
}


